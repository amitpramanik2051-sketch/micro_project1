    <p>Fresh vegetables, dairy, snacks and daily essentials — straight to your door. India's fastest grocery delivery, now in your city.</p>
    <div class="hero-cta">
      <button class="btn-primary" onclick="document.getElementById('categories').scrollIntoView({behavior:'smooth'})">Start Shopping</button>
      <button class="btn-secondary" id="heroSignup">Create Account</button>
    </div>
    <div class="hero-stats">
      <div class="stat"><strong>10 min</strong><span>Avg delivery time</span></div>
      <div class="stat"><strong>5000+</strong><span>Products</span></div>
      <div class="stat"><strong>4.8★</strong><span>App rating</span></div>
    </div>
  </div>
</section>

<!-- ===== LIVE TRACKING BANNER ===== -->
<div class="tracking-banner" id="trackingBanner">
  <div class="tracking-left">
    <div class="tracking-icon">🛵</div>
    <div class="tracking-text">
      <strong>Your order is on the way!</strong>
      <span id="trackingSummary">Rider is 1.8 km away</span>
