<script>
/* ============ DATA — REAL IMAGES via Unsplash source ============ */
const CATEGORIES = [
  {name:"Vegetables", img:"https://images.unsplash.com/photo-1540420773420-3366772f4999?w=300&h=200&fit=crop"},
  {name:"Fruits", img:"https://images.unsplash.com/photo-1610832958506-aa56368176cf?w=300&h=200&fit=crop"},
