<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Blinkit — Groceries in 10 minutes</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --yellow:#f6d600;
    --yellow-deep:#ffd900;
    --green:#0c831f;
    --green-light:#1ea83c;
    --green-glow:#36e05a;
    --dark:#1a1a1a;
    --gray:#6b7280;
    --bg:#f7f8fa;
    --card:#ffffff;
    --text:#1a1a1a;
    --border:#eee;
    --radius:16px;
    --shadow:0 4px 18px rgba(0,0,0,0.06);
    --shadow-hover:0 14px 36px rgba(0,0,0,0.13);
    --transition:all .35s cubic-bezier(.4,0,.2,1);
    --gradient-brand:linear-gradient(135deg,#0c831f 0%, #1ea83c 50%, #f6d600 150%);
  }

  [data-theme="dark"]{
    --bg:#0b0c0d;
    --card:#191a1c;
    --text:#f5f5f5;
    --gray:#9aa0a6;
    --border:#2a2c2f;
    --shadow:0 4px 18px rgba(0,0,0,0.5);
    --shadow-hover:0 16px 40px rgba(0,0,0,0.65);
  }

  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    font-family:'Inter','Segoe UI',system-ui,-apple-system,sans-serif;
    background:var(--bg);
    color:var(--text);
    overflow-x:hidden;
    transition:background .4s ease, color .4s ease;
    -webkit-font-smoothing:antialiased;
  }
  h1,h2,h3,h4,.logo,.section-title,.modal h2{font-family:'Poppins','Segoe UI',sans-serif;}

  ::-webkit-scrollbar{width:8px;}
  ::-webkit-scrollbar-thumb{background:var(--green);border-radius:10px;}

  a:focus-visible, button:focus-visible, input:focus-visible, .cat-card:focus-visible, .product-card:focus-visible{
    outline:3px solid var(--green-light);outline-offset:2px;
  }
  @media (prefers-reduced-motion: reduce){
    *{animation-duration:.01ms !important; animation-iteration-count:1 !important; transition-duration:.01ms !important;}
  }

  /* ===== Top Bar ===== */
  .topbar{
    position:sticky;top:0;z-index:1000;
    background:var(--card);
    box-shadow:var(--shadow);
    padding:14px 6%;
    display:flex;align-items:center;justify-content:space-between;
    gap:20px;
    animation:slideDown .6s ease;
    transition:background .4s ease;
  }
  @keyframes slideDown{from{transform:translateY(-100%);opacity:0;}to{transform:translateY(0);opacity:1;}}

  .logo{
    display:flex;align-items:center;gap:6px;
    font-size:26px;font-weight:900;
    cursor:pointer;
    transition:var(--transition);
    letter-spacing:-0.5px;
  }
  .logo .lg-blink{
    background:linear-gradient(135deg,var(--green) 20%, var(--green-light) 60%, var(--green-glow) 100%);
    -webkit-background-clip:text;background-clip:text;color:transparent;
    background-size:200% auto;
    animation:gradientShift 4s ease infinite;
  }
  @keyframes gradientShift{0%,100%{background-position:0% 50%;}50%{background-position:100% 50%;}}
  .logo:hover{transform:scale(1.05);}
  .logo .lg-it{
    color:var(--dark);background:var(--yellow-deep);
    border-radius:8px;padding:2px 10px;
    transition:var(--transition);
    box-shadow:0 4px 0 #b8a300;
  }
  [data-theme="dark"] .logo .lg-it{color:#1a1a1a;}
  .logo:hover .lg-it{transform:rotate(-8deg) scale(1.1);}

  .delivery-info{
    display:flex;flex-direction:column;cursor:pointer;
    transition:var(--transition);
    padding:6px 10px;border-radius:8px;
  }
  .delivery-info:hover{background:var(--bg);}
  .delivery-info .title{font-weight:800;font-size:15px;}
  .delivery-info .sub{font-size:12px;color:var(--gray);
    display:flex;align-items:center;gap:4px;}

  .search-box{
    flex:1;max-width:480px;
    display:flex;align-items:center;
    background:var(--bg);
    border:2px solid transparent;
    border-radius:10px;
    padding:10px 16px;
    transition:var(--transition);
  }
  .search-box:hover, .search-box:focus-within{
    border-color:var(--green-light);
    box-shadow:0 0 0 4px rgba(30,168,60,0.08);
  }
  .search-box input{
    border:none;outline:none;background:transparent;color:var(--text);
    width:100%;font-size:14px;margin-left:8px;
  }

  .nav-actions{display:flex;align-items:center;gap:14px;}

  .theme-toggle{
    width:52px;height:28px;border-radius:30px;
    background:var(--bg);border:2px solid var(--border);
    cursor:pointer;position:relative;
    transition:var(--transition);
    flex-shrink:0;
  }
  .theme-toggle .knob{
    position:absolute;top:2px;left:2px;
    width:20px;height:20px;border-radius:50%;
    background:linear-gradient(135deg,var(--yellow),var(--yellow-deep));
    display:flex;align-items:center;justify-content:center;font-size:11px;
    transition:transform .35s cubic-bezier(.4,0,.2,1);
  }
  [data-theme="dark"] .theme-toggle .knob{
    transform:translateX(22px);
    background:linear-gradient(135deg,#444,#222);
  }
  .theme-toggle:hover{border-color:var(--green-light);}

  .login-btn{
    background:var(--green);color:#fff;
    padding:10px 22px;border-radius:10px;font-size:14px;
    border:none;cursor:pointer;font-weight:700;font-family:inherit;
    transition:var(--transition);
    box-shadow:0 4px 0 #095c16;
  }
  .login-btn:hover{background:var(--green-light);transform:translateY(-2px);box-shadow:0 6px 0 #095c16;}
  .login-btn:active{transform:translateY(2px);box-shadow:0 2px 0 #095c16;}

  .cart-btn{
    background:var(--green);color:#fff;padding:10px 18px;border-radius:10px;font-size:14px;
    border:none;cursor:pointer;font-weight:700;font-family:inherit;
    display:flex;align-items:center;gap:8px;
    box-shadow:0 4px 0 #095c16;
    transition:var(--transition);
  }
  .cart-btn:hover{background:var(--green-light);transform:translateY(-2px);box-shadow:0 6px 0 #095c16;}
  .cart-count{
    background:var(--yellow-deep);color:#1a1a1a;
    border-radius:50%;width:20px;height:20px;
    display:flex;align-items:center;justify-content:center;
    font-size:11px;font-weight:800;
    animation:pop .3s ease;
  }
  @keyframes pop{0%{transform:scale(0);}80%{transform:scale(1.3);}100%{transform:scale(1);}}

  .avatar-circle{
    width:42px;height:42px;border-radius:50%;
    background:linear-gradient(135deg,var(--green),var(--green-light));
    color:#fff;display:flex;align-items:center;justify-content:center;
    font-weight:800;cursor:pointer;font-size:16px;
    border:2px solid var(--yellow-deep);
    transition:var(--transition);
  }
  .avatar-circle:hover{transform:scale(1.1) rotate(8deg);box-shadow:0 0 0 5px rgba(246,214,0,0.3);}

  /* ===== Hero ===== */
  .hero{
    position:relative;
    background:linear-gradient(120deg,var(--green) 0%, var(--green-light) 45%, #57c970 80%, var(--green-glow) 100%);
    background-size:200% 200%;
    animation:heroGradient 12s ease infinite;
    color:#fff;
    padding:60px 6% 100px;
    overflow:hidden;
    border-radius:0 0 40px 40px;
  }
  @keyframes heroGradient{0%,100%{background-position:0% 50%;}50%{background-position:100% 50%;}}
  .hero::before, .hero::after{
    content:'';position:absolute;border-radius:50%;
    background:rgba(255,255,255,0.08);
  }
  .hero::before{width:300px;height:300px;top:-100px;right:-60px;animation:float 8s ease-in-out infinite;}
  .hero::after{width:180px;height:180px;bottom:-60px;left:10%;animation:float 6s ease-in-out infinite reverse;}
  .hero-blob{
    position:absolute;border-radius:50%;background:rgba(255,255,255,0.06);
    pointer-events:none;
  }
  .hero-blob.b1{width:120px;height:120px;top:30%;right:20%;animation:float 7s ease-in-out infinite;}
  .hero-blob.b2{width:80px;height:80px;bottom:15%;right:35%;animation:float 5s ease-in-out infinite reverse;}
  @keyframes float{0%,100%{transform:translateY(0) scale(1);}50%{transform:translateY(-25px) scale(1.08);}}

  .hero-content{position:relative;z-index:2;max-width:640px;animation:fadeUp 1s ease;}
  @keyframes fadeUp{from{opacity:0;transform:translateY(30px);}to{opacity:1;transform:translateY(0);}}

  .hero-badge{
    display:inline-flex;align-items:center;gap:6px;
    background:rgba(255,255,255,0.18);
    padding:6px 16px;border-radius:30px;
    font-size:13px;font-weight:700;margin-bottom:18px;
    backdrop-filter:blur(4px);
    animation:pulse 2.4s infinite;
  }
  @keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(255,255,255,0.3);}50%{box-shadow:0 0 0 8px rgba(255,255,255,0);}}

  .hero h1{
    font-size:clamp(34px,6vw,58px);
    font-weight:900;line-height:1.1;margin-bottom:14px;
  }
  .hero h1 .highlight{
    color:var(--yellow-deep);position:relative;
    display:inline-block;
  }
  .hero h1 .highlight::after{
    content:'';position:absolute;left:0;bottom:4px;width:100%;height:10px;
    background:rgba(255,217,0,0.35);z-index:-1;border-radius:6px;
    transform:scaleX(0);transform-origin:left;
    animation:underlineGrow 1s ease-out .6s forwards;
  }
  @keyframes underlineGrow{to{transform:scaleX(1);}}

  .hero p{font-size:17px;opacity:.95;margin-bottom:26px;max-width:480px;}

  .hero-stats{
    display:flex;gap:28px;margin-top:36px;flex-wrap:wrap;
  }
  .hero-stats .stat{
    display:flex;flex-direction:column;gap:2px;
    animation:fadeUp 1s ease both;
    animation-delay:.3s;
  }
  .hero-stats .stat strong{font-size:24px;font-weight:900;color:var(--yellow-deep);}
  .hero-stats .stat span{font-size:12px;opacity:.85;}

  .hero-cta{display:flex;gap:14px;flex-wrap:wrap;}
  .btn-primary, .btn-secondary{
    padding:14px 30px;border-radius:12px;
    border:none;font-weight:800;font-size:15px;cursor:pointer;
    transition:var(--transition);
    position:relative;overflow:hidden;
  }
  .btn-primary{
    background:var(--yellow-deep);color:#1a1a1a;
    box-shadow:0 6px 0 #b8a300;
  }
  .btn-primary::after{
    content:'';position:absolute;top:0;left:-75%;width:50%;height:100%;
    background:linear-gradient(120deg, transparent, rgba(255,255,255,.5), transparent);
    transform:skewX(-20deg);
  }
  .btn-primary:hover::after{
    animation:shine 1s ease;
  }
  @keyframes shine{from{left:-75%;}to{left:125%;}}
  .btn-primary:hover{transform:translateY(-3px);box-shadow:0 9px 0 #b8a300, 0 0 20px rgba(255,217,0,0.5);}
  .btn-primary:active{transform:translateY(3px);box-shadow:0 2px 0 #b8a300;}
  .btn-secondary{
    background:rgba(255,255,255,0.15);color:#fff;
    border:2px solid rgba(255,255,255,0.5);
    backdrop-filter:blur(4px);
  }
  .btn-secondary:hover{background:rgba(255,255,255,0.3);transform:translateY(-3px);box-shadow:0 0 20px rgba(255,255,255,0.3);}

  /* ===== Sections ===== */
  .section{padding:50px 6%;}
  .section-title{
    font-size:26px;font-weight:900;margin-bottom:22px;
    display:flex;align-items:center;justify-content:space-between;
  }
  .section-title span.tag{
    font-size:13px;color:var(--green);font-weight:700;
    cursor:pointer;transition:var(--transition);
  }
  .section-title span.tag:hover{transform:translateX(4px);text-decoration:underline;}

  /* ===== Categories ===== */
  .cat-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(130px,1fr));
    gap:18px;
  }
  .cat-card{
    background:var(--card);
    border-radius:var(--radius);
    text-align:center;
    cursor:pointer;
    box-shadow:var(--shadow);
    transition:var(--transition);
    position:relative;
    overflow:hidden;
    border:2px solid transparent;
  }
  .cat-card .cat-img-wrap{
    width:100%;height:90px;overflow:hidden;
  }
  .cat-card img{
    width:100%;height:100%;object-fit:cover;
    transition:transform .5s cubic-bezier(.4,0,.2,1), filter .5s;
    display:block;
  }
  .cat-card:hover img{transform:scale(1.15) rotate(2deg);filter:brightness(1.08);}
  .cat-card:hover{
    transform:translateY(-8px) scale(1.03);
    box-shadow:var(--shadow-hover);
    border-color:var(--green-light);
  }
  .cat-card .name{font-weight:700;font-size:13px;padding:10px 6px;}

  /* ===== Products ===== */
  .product-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(200px,1fr));
    gap:20px;
  }
  .product-card{
    background:var(--card);
    border-radius:var(--radius);
    padding:14px;
    box-shadow:var(--shadow);
    transition:var(--transition);
    cursor:pointer;
    position:relative;
    display:flex;flex-direction:column;
    border:1px solid var(--border);
  }
  .product-card:hover{
    transform:translateY(-6px);
    box-shadow:var(--shadow-hover);
    border-color:var(--green-light);
  }
  .product-badge{
    position:absolute;top:12px;left:12px;
    background:var(--green);color:#fff;
    font-size:11px;font-weight:800;
    padding:4px 8px;border-radius:6px;
    z-index:2;
    animation:fadeUp .6s ease;
  }
  .product-img{
    width:100%;height:140px;border-radius:10px;
    background:var(--bg);
    display:flex;align-items:center;justify-content:center;
    margin-bottom:12px;
    overflow:hidden;
    position:relative;
  }
  .product-img img{
    width:100%;height:100%;object-fit:cover;
    transition:transform .5s cubic-bezier(.4,0,.2,1), filter .5s;
  }
  .product-card:hover .product-img img{transform:scale(1.12);filter:brightness(1.05) saturate(1.1);}

  .product-weight{font-size:12px;color:var(--gray);margin-bottom:4px;}
  .product-name{font-weight:700;font-size:14px;margin-bottom:8px;min-height:36px;}

  .product-footer{display:flex;align-items:center;justify-content:space-between;margin-top:auto;}
  .product-price{font-weight:800;font-size:15px;}
  .product-price .old{text-decoration:line-through;color:var(--gray);font-size:12px;font-weight:400;margin-left:6px;}

  .add-btn{
    border:1.5px solid var(--green);
    background:var(--card);color:var(--green);
    font-weight:800;font-size:13px;
    padding:7px 18px;border-radius:9px;
    cursor:pointer;transition:var(--transition);
    position:relative;overflow:hidden;
  }
  .add-btn::before{
    content:'';position:absolute;inset:0;
    background:var(--green);
    transform:scaleX(0);transform-origin:left;
    transition:transform .35s ease;
    z-index:0;border-radius:9px;
  }
  .add-btn span{position:relative;z-index:1;transition:color .35s;}
  .add-btn:hover::before{transform:scaleX(1);}
  .add-btn:hover span{color:#fff;}
  .add-btn:active{transform:scale(.92);}
  .add-btn.added{background:var(--green);color:#fff;border-color:var(--green);}
  .add-btn.added span{color:#fff;}

  /* ===== Trust Strip ===== */
  .trust-strip{
    background:var(--card);
    padding:40px 6%;
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:24px;
    border-top:1px solid var(--border);border-bottom:1px solid var(--border);
    transition:background .4s ease;
  }
  .trust-item{display:flex;align-items:flex-start;gap:14px;padding:18px;border-radius:var(--radius);transition:var(--transition);}
  .trust-item:hover{background:var(--bg);transform:translateX(6px);}
  .trust-item .icon{
    width:48px;height:48px;border-radius:12px;
    background:linear-gradient(135deg,var(--yellow),var(--yellow-deep));
    display:flex;align-items:center;justify-content:center;
    font-size:24px;flex-shrink:0;transition:var(--transition);
  }
  .trust-item:hover .icon{transform:rotate(-10deg) scale(1.1);}
  .trust-item h4{font-size:15px;margin-bottom:4px;}
  .trust-item p{font-size:13px;color:var(--gray);}
  .verified-tick{color:var(--green);font-weight:900;}

  /* ===== Live Tracking Banner ===== */
  .tracking-banner{
    display:none;
    background:var(--card);
    border-radius:var(--radius);
    box-shadow:var(--shadow);
    padding:18px 22px;
    margin:0 6% 30px;
    align-items:center;justify-content:space-between;
    gap:18px;
    border:1px solid var(--border);
    animation:slideUpBanner .5s cubic-bezier(.34,1.56,.64,1);
    cursor:pointer;
    transition:var(--transition);
    flex-wrap:wrap;
  }
  .tracking-banner.show{display:flex;}
  .tracking-banner:hover{box-shadow:var(--shadow-hover);transform:translateY(-2px);}
  @keyframes slideUpBanner{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
  .tracking-left{display:flex;align-items:center;gap:14px;}
  .tracking-icon{
    width:50px;height:50px;border-radius:50%;
    background:linear-gradient(135deg,var(--green),var(--green-light));
    display:flex;align-items:center;justify-content:center;font-size:24px;color:#fff;
    animation:bikeWiggle 1.2s ease-in-out infinite;
  }
  @keyframes bikeWiggle{0%,100%{transform:rotate(-6deg);}50%{transform:rotate(6deg);}}
  .tracking-text strong{display:block;font-size:14px;}
  .tracking-text span{font-size:12px;color:var(--gray);}
  .tracking-status{
    font-size:12px;font-weight:800;color:var(--green);
    background:#eafdf0;padding:5px 12px;border-radius:20px;
  }
  [data-theme="dark"] .tracking-status{background:rgba(30,168,60,.15);}

  /* ===== Footer ===== */
  footer{background:#111315;color:#ccc;padding:46px 6% 26px;margin-top:30px;}
  .footer-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:26px;margin-bottom:30px;}
  .footer-grid h4{color:#fff;margin-bottom:14px;font-size:15px;}
  .footer-grid a{display:block;color:#ccc;text-decoration:none;font-size:13px;margin-bottom:8px;transition:var(--transition);}
  .footer-grid a:hover{color:var(--yellow-deep);transform:translateX(4px);}
  .footer-bottom{border-top:1px solid #333;padding-top:18px;text-align:center;font-size:12px;color:#888;}

  /* ===== Modal Overlay ===== */
  .overlay{
    position:fixed;inset:0;background:rgba(0,0,0,0.5);
    display:none;align-items:center;justify-content:center;
    z-index:2000;backdrop-filter:blur(3px);
    animation:fadeIn .3s ease;
  }
  .overlay.show{display:flex;}
  @keyframes fadeIn{from{opacity:0;}to{opacity:1;}}

  .modal{
    background:var(--card);color:var(--text);
    border-radius:18px;width:380px;max-width:92vw;padding:32px 28px;
    box-shadow:0 25px 60px rgba(0,0,0,0.25);
    position:relative;
    animation:popIn .35s cubic-bezier(.34,1.56,.64,1);
    max-height:90vh;overflow-y:auto;
    border:1px solid var(--border);
  }
  @keyframes popIn{from{opacity:0;transform:scale(.85) translateY(20px);}to{opacity:1;transform:scale(1) translateY(0);}}

  .modal-close{
    position:absolute;top:16px;right:18px;
    background:none;border:none;font-size:22px;
    cursor:pointer;color:var(--gray);
    transition:var(--transition);
    width:32px;height:32px;border-radius:50%;
  }
  .modal-close:hover{background:var(--bg);color:var(--text);transform:rotate(90deg);}

  .modal h2{font-size:24px;font-weight:900;margin-bottom:6px;display:flex;align-items:center;gap:8px;}
  .modal p.subtitle{font-size:13px;color:var(--gray);margin-bottom:22px;}

  .form-group{margin-bottom:16px;position:relative;}
  .form-group label{display:block;font-size:12px;font-weight:700;margin-bottom:6px;color:var(--gray);text-transform:uppercase;letter-spacing:.5px;}
  .form-group input{
    width:100%;padding:13px 14px;
    border:2px solid var(--border);border-radius:10px;
    font-size:14px;outline:none;
    transition:var(--transition);
    background:var(--bg);color:var(--text);
  }
  .form-group input:focus{
    border-color:var(--green-light);
    box-shadow:0 0 0 4px rgba(30,168,60,0.1);
    transform:translateY(-2px);
  }
  .form-group .error-msg{font-size:11px;color:#e74c3c;margin-top:4px;display:none;}
  .form-group.invalid input{border-color:#e74c3c;}
  .form-group.invalid .error-msg{display:block;animation:fadeUp .3s;}

  .otp-inputs{display:flex;gap:10px;justify-content:center;margin:18px 0;}
  .otp-inputs input{
    width:46px;height:54px;text-align:center;
    font-size:20px;font-weight:800;
    border:2px solid var(--border);border-radius:10px;
    background:var(--bg);color:var(--text);outline:none;
    transition:var(--transition);
  }
  .otp-inputs input:focus{
    border-color:var(--green-light);
    box-shadow:0 0 0 4px rgba(30,168,60,0.1);
    transform:scale(1.08);
  }
  .otp-inputs input.filled{border-color:var(--green);background:rgba(30,168,60,.1);}

  .modal-btn{
    width:100%;padding:14px;border:none;border-radius:11px;
    background:var(--green);color:#fff;font-weight:800;font-size:15px;
    cursor:pointer;transition:var(--transition);
    box-shadow:0 5px 0 #095c16;margin-top:6px;
  }
  .modal-btn:hover{background:var(--green-light);transform:translateY(-2px);box-shadow:0 7px 0 #095c16;}
  .modal-btn:active{transform:translateY(2px);box-shadow:0 1px 0 #095c16;}

  .switch-link{text-align:center;font-size:13px;margin-top:18px;color:var(--gray);}
  .switch-link b{color:var(--green);cursor:pointer;font-weight:800;transition:var(--transition);}
  .switch-link b:hover{text-decoration:underline;}

  .resend-row{text-align:center;font-size:12px;color:var(--gray);margin-top:10px;}
  .resend-row b{color:var(--green);cursor:pointer;}
  .resend-row b.disabled{color:#aaa;cursor:not-allowed;pointer-events:none;}

  .step{display:none;animation:fadeUp .4s ease;}
  .step.active{display:block;}

  /* Profile Modal */
  .profile-header{display:flex;align-items:center;gap:16px;margin-bottom:22px;}
  .profile-avatar{
    width:64px;height:64px;border-radius:50%;
    background:linear-gradient(135deg,var(--green),var(--green-light));
    color:#fff;display:flex;align-items:center;justify-content:center;
    font-size:26px;font-weight:800;
    border:3px solid var(--yellow-deep);transition:var(--transition);
  }
  .profile-header:hover .profile-avatar{transform:rotate(10deg) scale(1.05);}
  .profile-header h3{font-size:18px;}
  .profile-header .badge-verified{
    display:inline-flex;align-items:center;gap:4px;
    font-size:11px;color:var(--green);font-weight:800;
    background:#eafdf0;padding:3px 8px;border-radius:6px;margin-top:4px;
  }
  [data-theme="dark"] .profile-header .badge-verified{background:rgba(30,168,60,.15);}

  .profile-list{display:flex;flex-direction:column;gap:8px;margin-bottom:18px;}
  .profile-list .item{
    display:flex;align-items:center;justify-content:space-between;
    padding:13px 14px;border-radius:10px;
    background:var(--bg);cursor:pointer;
    transition:var(--transition);font-size:14px;font-weight:600;
  }
  .profile-list .item:hover{background:rgba(30,168,60,.1);transform:translateX(6px);box-shadow:var(--shadow);}
  .profile-list .item .left{display:flex;align-items:center;gap:10px;}
  .profile-list .item.logout{color:#e74c3c;}
  .profile-list .item.logout:hover{background:rgba(231,76,60,.1);}

  /* Cart Drawer */
  .cart-drawer{
    position:fixed;top:0;right:-420px;width:400px;max-width:92vw;height:100vh;
    background:var(--card);color:var(--text);z-index:2100;
    box-shadow:-10px 0 30px rgba(0,0,0,0.15);
    transition:right .4s cubic-bezier(.4,0,.2,1), background .4s;
    display:flex;flex-direction:column;
  }
  .cart-drawer.show{right:0;}
  .cart-header{padding:20px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
  .cart-header h3{font-size:18px;font-weight:900;}
  .cart-items{flex:1;overflow-y:auto;padding:14px 20px;}
  .cart-item{
    display:flex;align-items:center;gap:12px;
    padding:12px 0;border-bottom:1px solid var(--border);
    animation:fadeUp .35s ease;
  }
  .cart-item .img{width:50px;height:50px;border-radius:8px;background:var(--bg);overflow:hidden;flex-shrink:0;}
  .cart-item .img img{width:100%;height:100%;object-fit:cover;}
  .cart-item .info{flex:1;}
  .cart-item .info .name{font-weight:700;font-size:13px;}
  .cart-item .info .price{font-size:12px;color:var(--gray);}
  .qty-control{display:flex;align-items:center;gap:8px;background:var(--green);border-radius:8px;overflow:hidden;}
  .qty-control button{background:none;border:none;color:#fff;font-weight:900;width:26px;height:26px;cursor:pointer;font-size:15px;transition:var(--transition);}
  .qty-control button:hover{background:var(--green-light);}
  .qty-control span{color:#fff;font-weight:800;font-size:13px;}
  .cart-empty{text-align:center;padding:60px 20px;color:var(--gray);}
  .cart-empty .emoji{font-size:60px;margin-bottom:14px;display:block;animation:float 4s ease-in-out infinite;}
  .cart-footer{padding:18px 20px;border-top:1px solid var(--border);}
  .cart-total-row{display:flex;justify-content:space-between;font-weight:800;margin-bottom:14px;font-size:15px;}

  /* Toast / Alerts */
  .toast-container{position:fixed;bottom:24px;right:24px;z-index:3000;display:flex;flex-direction:column;gap:10px;}
  .toast{
    background:var(--card);color:var(--text);border-radius:12px;
    padding:14px 18px;min-width:280px;max-width:340px;
    box-shadow:0 12px 30px rgba(0,0,0,0.15);
    display:flex;align-items:center;gap:12px;
    border-left:5px solid var(--green);
    animation:toastIn .4s cubic-bezier(.34,1.56,.64,1);
  }
  .toast.error{border-left-color:#e74c3c;}
  .toast.info{border-left-color:#3498db;}
  @keyframes toastIn{from{opacity:0;transform:translateX(60px);}to{opacity:1;transform:translateX(0);}}
  .toast.hide{animation:toastOut .35s forwards;}
  @keyframes toastOut{to{opacity:0;transform:translateX(60px);}}
  .toast .icon{font-size:22px;}
  .toast .text strong{display:block;font-size:13px;}
  .toast .text span{font-size:12px;color:var(--gray);}

  .drawer-bg{position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:2050;display:none;animation:fadeIn .3s;}
  .drawer-bg.show{display:block;}

  /* ===== Map Tracking Modal ===== */
  .map-modal{
    background:var(--card);color:var(--text);
    border-radius:18px;width:420px;max-width:92vw;
    box-shadow:0 25px 60px rgba(0,0,0,0.3);
    animation:popIn .35s cubic-bezier(.34,1.56,.64,1);
    overflow:hidden;border:1px solid var(--border);
  }
  .map-header{padding:18px 22px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
  .map-header h3{font-size:17px;font-weight:900;}
  .map-canvas-wrap{
    position:relative;height:240px;
    background:
      linear-gradient(var(--bg), var(--bg)),
      repeating-linear-gradient(0deg, transparent, transparent 23px, rgba(120,120,120,.12) 23px, rgba(120,120,120,.12) 24px),
      repeating-linear-gradient(90deg, transparent, transparent 23px, rgba(120,120,120,.12) 23px, rgba(120,120,120,.12) 24px);
    overflow:hidden;
  }
  .route-line{
    position:absolute;top:50%;left:8%;width:84%;height:3px;
    background:repeating-linear-gradient(90deg, var(--green) 0 10px, transparent 10px 18px);
    transform:translateY(-50%);
    border-radius:4px;
  }
  .map-point{
    position:absolute;top:50%;transform:translate(-50%,-50%);
    width:38px;height:38px;border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    font-size:18px;box-shadow:0 4px 10px rgba(0,0,0,.2);
  }
  .map-point.store{left:8%;background:var(--yellow-deep);}
  .map-point.home{left:92%;background:var(--green);color:#fff;}
  .map-rider{
    position:absolute;top:50%;left:8%;transform:translate(-50%,-50%);
    width:42px;height:42px;border-radius:50%;
    background:#fff;border:3px solid var(--green);
    display:flex;align-items:center;justify-content:center;font-size:20px;
    box-shadow:0 6px 16px rgba(0,0,0,.25);
    transition:left 1s linear;
    z-index:5;
  }
  .map-rider::after{
    content:'';position:absolute;inset:-8px;border-radius:50%;
    border:2px solid var(--green);opacity:.5;
    animation:radar 1.6s ease-out infinite;
  }
  @keyframes radar{0%{transform:scale(.6);opacity:.6;}100%{transform:scale(1.8);opacity:0;}}

  .map-info{padding:18px 22px;}
  .map-eta{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
  .map-eta .big{font-size:26px;font-weight:900;color:var(--green);}
  .map-eta .label{font-size:12px;color:var(--gray);}
  .progress-track{height:8px;background:var(--bg);border-radius:6px;overflow:hidden;margin-bottom:16px;}
  .progress-fill{
    height:100%;background:linear-gradient(90deg,var(--green),var(--green-light));
    width:0%;border-radius:6px;
    transition:width 1s linear;
  }
  .status-steps{display:flex;justify-content:space-between;font-size:11px;color:var(--gray);}
  .status-steps .step-pt{display:flex;flex-direction:column;align-items:center;gap:6px;flex:1;}
  .status-steps .dot{width:12px;height:12px;border-radius:50%;background:var(--border);transition:var(--transition);}
  .status-steps .step-pt.active .dot{background:var(--green);box-shadow:0 0 0 4px rgba(30,168,60,.15);}
  .status-steps .step-pt.active{color:var(--green);font-weight:700;}

  /* Scroll-reveal */
  .reveal{opacity:0;transform:translateY(40px);transition:all .7s cubic-bezier(.4,0,.2,1);}
  .reveal.visible{opacity:1;transform:translateY(0);}

  /* ===== Mobile Bottom Nav ===== */
  .bottom-nav{
    display:none;
    position:fixed;bottom:0;left:0;right:0;z-index:1500;
    background:var(--card);
    border-top:1px solid var(--border);
    box-shadow:0 -4px 20px rgba(0,0,0,0.08);
    padding:6px 4px;
    justify-content:space-around;
    align-items:center;
  }
  .bn-item{
    background:none;border:none;cursor:pointer;
    display:flex;flex-direction:column;align-items:center;gap:3px;
    font-size:11px;font-weight:600;color:var(--gray);
    padding:6px 8px;border-radius:10px;
    transition:var(--transition);
    position:relative;flex:1;
    font-family:inherit;
  }
  .bn-icon{font-size:20px;transition:var(--transition);}
  .bn-item.active{color:var(--green);}
  .bn-item.active .bn-icon{transform:translateY(-3px) scale(1.15);}
  .bn-item:active{transform:scale(.9);}
  .bn-badge{
    position:absolute;top:-2px;right:6px;
    background:var(--yellow-deep);color:#1a1a1a;
    font-size:9px;font-weight:800;
    border-radius:50%;width:15px;height:15px;
    display:flex;align-items:center;justify-content:center;
    animation:pop .3s ease;
  }

  /* ===== Skeleton Loading ===== */
  .skeleton{
    background:linear-gradient(90deg, var(--border) 25%, rgba(255,255,255,.3) 50%, var(--border) 75%);
    background-size:200% 100%;
    animation:shimmer 1.4s ease infinite;
    border-radius:8px;
  }
  @keyframes shimmer{0%{background-position:200% 0;}100%{background-position:-200% 0;}}

  /* ===== RESPONSIVE ===== */
  @media(max-width:1024px){
    .product-grid{grid-template-columns:repeat(auto-fill,minmax(170px,1fr));}
    .cat-grid{grid-template-columns:repeat(auto-fit,minmax(110px,1fr));}
  }

  @media(max-width:768px){
    body{padding-bottom:70px;}
    .topbar{padding:12px 4%;gap:10px;}
    .search-box{display:none;}
    .delivery-info{display:none;}
    .hero{padding:36px 5% 60px;border-radius:0 0 28px 28px;}
    .hero h1{font-size:32px;}
    .hero p{font-size:14px;}
    .hero-cta{gap:10px;}
    .btn-primary, .btn-secondary{padding:12px 22px;font-size:13px;}
    .hero-stats{gap:18px;margin-top:26px;}
    .hero-stats .stat strong{font-size:19px;}
    .section{padding:32px 4%;}
    .section-title{font-size:20px;}
    .tracking-banner{margin:0 4% 20px;padding:14px 16px;}
    .tracking-text strong{font-size:13px;}
    .product-grid{grid-template-columns:repeat(2,1fr);gap:12px;}
    .cat-grid{grid-template-columns:repeat(3,1fr);gap:10px;}
    .product-img{height:110px;}
    .modal{padding:24px 18px;}
    .otp-inputs input{width:42px;height:50px;font-size:18px;}
    .cart-drawer{width:100%;}
    .bottom-nav{display:flex;}
    .nav-actions .cart-btn{display:none;}
    footer{padding-bottom:90px;}
  }

  @media(max-width:480px){
    .hero h1{font-size:27px;}
    .product-grid{grid-template-columns:repeat(2,1fr);gap:10px;}
    .cat-grid{grid-template-columns:repeat(3,1fr);gap:8px;}
    .cat-card .name{font-size:11px;padding:8px 4px;}
    .logo{font-size:22px;}
    .theme-toggle{width:46px;height:25px;}
    .theme-toggle .knob{width:18px;height:18px;}
    [data-theme="dark"] .theme-toggle .knob{transform:translateX(19px);}
    .product-name{font-size:13px;min-height:34px;}
    .add-btn{padding:6px 14px;font-size:12px;}
    .hero-stats{gap:14px;}
    .map-modal{width:94vw;}
    .toast{min-width:240px;max-width:88vw;right:0;}
    .toast-container{right:12px;bottom:80px;left:12px;}
    .toast{max-width:none;}
  }

  @media(min-width:1400px){
    .product-grid{grid-template-columns:repeat(6,1fr);}
    .cat-grid{grid-template-columns:repeat(8,1fr);}
  }
</style>
</head>
<body>

<!-- ===== TOP BAR ===== -->
<header class="topbar">
  <div class="logo" onclick="window.scrollTo({top:0,behavior:'smooth'})"><span class="lg-blink">Blink</span><span class="lg-it">it</span></div>
  <div class="delivery-info">
    <div class="title">Delivery in 10 minutes</div>
    <div class="sub">📍 Home - Bhopal, MP &nbsp;▾</div>
  </div>
  <div class="search-box">
    <span>🔍</span>
    <input type="text" placeholder="Search for atta, dal, oil etc.">
  </div>
  <div class="nav-actions">
    <div class="theme-toggle" id="themeToggle" title="Toggle dark mode"><div class="knob">🌙</div></div>
    <button class="cart-btn" id="cartBtn">🛒 Cart <span class="cart-count" id="cartCount">0</span></button>
    <div id="authArea">
      <button class="login-btn" id="loginOpenBtn">Login</button>
    </div>
  </div>
</header>

<!-- ===== HERO ===== -->
<section class="hero">
  <div class="hero-blob b1"></div>
  <div class="hero-blob b2"></div>
  <div class="hero-content">
    <div class="hero-badge">⚡ Delivering in 10 minutes</div>
