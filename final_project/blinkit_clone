const PRODUCTS = [
  {id:1, name:"Fresh Red Onion (1kg)", img:"https://images.unsplash.com/photo-1618512496248-a07fe83aa8cb?w=400&h=300&fit=crop", price:32, old:40, badge:"15% OFF"},
  {id:2, name:"Full Cream Milk (1L)", img:"https://images.unsplash.com/photo-1563636619-e9143da7973b?w=400&h=300&fit=crop", price:66, old:null, badge:null},
  {id:3, name:"Banana Robusta (6pc)", img:"https://images.unsplash.com/photo-1571771894821-ce9b6c11b08e?w=400&h=300&fit=crop", price:48, old:55, badge:"BESTSELLER"},
  {id:4, name:"Fresh Tomato (1kg)", img:"https://images.unsplash.com/photo-1582284540020-8acbe03f4924?w=400&h=300&fit=crop", price:28, old:35, badge:"20% OFF"},
  {id:5, name:"Brown Bread Loaf", img:"https://images.unsplash.com/photo-1509440159596-0249088772ff?w=400&h=300&fit=crop", price:45, old:null, badge:null},
  {id:6, name:"Classic Salted Chips", img:"https://images.unsplash.com/photo-1566478989037-eec170784d0b?w=400&h=300&fit=crop", price:20, old:25, badge:"OFFER"},
  {id:7, name:"Iodized Salt (1kg)", img:"https://images.unsplash.com/photo-1622037022824-0c71f411ee8d?w=400&h=300&fit=crop", price:25, old:null, badge:null},
  {id:8, name:"Chilled Cola (750ml)", img:"https://images.unsplash.com/photo-1554866585-cd94860890b7?w=400&h=300&fit=crop", price:40, old:45, badge:"COLD"},
  {id:9, name:"Farm Eggs (6pc Tray)", img:"https://images.unsplash.com/photo-1582722872445-44dc5f7e3c8f?w=400&h=300&fit=crop", price:42, old:48, badge:"FRESH"},
  {id:10, name:"Instant Noodles (4pk)", img:"https://images.unsplash.com/photo-1612929633738-8fe44f7ec841?w=400&h=300&fit=crop", price:56, old:64, badge:"OFFER"},
  {id:11, name:"Premium Chocolate Bar", img:"https://images.unsplash.com/photo-1606312619070-d48b4c652a52?w=400&h=300&fit=crop", price:80, old:90, badge:"10% OFF"},
  {id:12, name:"Basmati Rice (5kg)", img:"https://images.unsplash.com/photo-1586201375761-83865001e31c?w=400&h=300&fit=crop", price:399, old:450, badge:"VALUE PACK"},
];

let cart = {};
let currentUser = null;
let signupMode = false;
let pendingPhone = "";
let pendingName = "";
let generatedOtp = "";
let resendInterval = null;
let trackingTimer = null;
let trackingProgress = 0;

/* ============ THEME TOGGLE ============ */
const themeToggle = document.getElementById('themeToggle');
const knob = themeToggle.querySelector('.knob');
function setTheme(dark){
  document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
  knob.textContent = dark ? '🌙' : '☀️';
}
themeToggle.addEventListener('click', ()=>{
  const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
  setTheme(!isDark);
  showToast(!isDark ? 'Dark Mode On 🌙' : 'Light Mode On ☀️', 'Theme preference updated', 'info', !isDark?'🌙':'☀️');
});
// default to light
setTheme(false);

/* ============ RENDER CATEGORIES ============ */
const catGrid = document.getElementById('catGrid');
CATEGORIES.forEach(c=>{
  const card = document.createElement('div');
  card.className = 'cat-card';
  card.innerHTML = `
    <div class="cat-img-wrap"><img src="${c.img}" alt="${c.name}" loading="lazy"></div>
    <div class="name">${c.name}</div>
  `;
  card.addEventListener('click', ()=>document.getElementById('products').scrollIntoView({behavior:'smooth'}));
  catGrid.appendChild(card);
});

/* ============ RENDER PRODUCTS ============ */
const grid = document.getElementById('productGrid');
PRODUCTS.forEach(p=>{
  const card = document.createElement('div');
  card.className = 'product-card';
  card.innerHTML = `
    ${p.badge ? `<div class="product-badge">${p.badge}</div>` : ''}
    <div class="product-img"><img src="${p.img}" alt="${p.name}" loading="lazy"></div>
    <div class="product-weight">Delivery in 10 mins</div>
    <div class="product-name">${p.name}</div>
    <div class="product-footer">
      <div class="product-price">₹${p.price}${p.old ? `<span class="old">₹${p.old}</span>`:''}</div>
      <button class="add-btn" data-id="${p.id}"><span>ADD</span></button>
    </div>
  `;
  grid.appendChild(card);
});

/* ============ TOASTS ============ */
function showToast(title, msg, type='success', icon='🔔'){
  const container = document.getElementById('toastContainer');
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.innerHTML = `<div class="icon">${icon}</div><div class="text"><strong>${title}</strong><span>${msg}</span></div>`;
  container.appendChild(toast);
  setTimeout(()=>{
    toast.classList.add('hide');
    setTimeout(()=>toast.remove(), 400);
  }, 3500);
}

/* ============ ADD TO CART ============ */
document.addEventListener('click', (e)=>{
  if(e.target.closest('.add-btn')){
    const btn = e.target.closest('.add-btn');
    const id = btn.dataset.id;
    cart[id] = (cart[id]||0) + 1;
    updateCartUI();
    btn.classList.add('added');
    btn.querySelector('span').textContent = `${cart[id]} ADDED`;
    showToast('Added to cart', `${PRODUCTS.find(p=>p.id==id).name} added successfully`, 'success', '🛒');
  }
});

function updateCartUI(){
  const count = Object.values(cart).reduce((a,b)=>a+b,0);
  document.getElementById('cartCount').textContent = count;
  const itemsEl = document.getElementById('cartItems');
  const footerEl = document.getElementById('cartFooter');

  if(count === 0){
    itemsEl.innerHTML = `<div class="cart-empty"><span class="emoji">🛍️</span><p>Your cart is empty.<br>Add items to get started!</p></div>`;
    footerEl.style.display = 'none';
    return;
  }

  footerEl.style.display = 'block';
  let total = 0;
  itemsEl.innerHTML = '';
  Object.entries(cart).forEach(([id,qty])=>{
    const p = PRODUCTS.find(pr=>pr.id==id);
    total += p.price * qty;
    const item = document.createElement('div');
    item.className = 'cart-item';
    item.innerHTML = `
      <div class="img"><img src="${p.img}" alt="${p.name}"></div>
      <div class="info">
        <div class="name">${p.name}</div>
        <div class="price">₹${p.price} x ${qty}</div>
      </div>
      <div class="qty-control">
        <button data-act="dec" data-id="${id}">−</button>
        <span>${qty}</span>
        <button data-act="inc" data-id="${id}">+</button>
      </div>
    `;
    itemsEl.appendChild(item);
  });
  document.getElementById('cartTotal').textContent = `₹${total}`;
}

document.getElementById('cartItems').addEventListener('click', (e)=>{
  const btn = e.target.closest('button[data-act]');
  if(!btn) return;
  const id = btn.dataset.id;
  if(btn.dataset.act === 'inc') cart[id]++;
  else {
    cart[id]--;
    if(cart[id]<=0) delete cart[id];
  }
  const addBtn = document.querySelector(`.add-btn[data-id="${id}"]`);
  if(addBtn){
    if(cart[id]){ addBtn.querySelector('span').textContent = `${cart[id]} ADDED`; addBtn.classList.add('added'); }
    else { addBtn.querySelector('span').textContent = 'ADD'; addBtn.classList.remove('added'); }
  }
  updateCartUI();
});

/* ============ CART DRAWER ============ */
const cartDrawer = document.getElementById('cartDrawer');
const drawerBg = document.getElementById('drawerBg');
document.getElementById('cartBtn').addEventListener('click', ()=>{
  cartDrawer.classList.add('show');
  drawerBg.classList.add('show');
});
function closeCartDrawer(){
  cartDrawer.classList.remove('show');
  drawerBg.classList.remove('show');
}
document.getElementById('closeCart').addEventListener('click', closeCartDrawer);
drawerBg.addEventListener('click', closeCartDrawer);

document.getElementById('checkoutBtn').addEventListener('click', ()=>{
  if(!currentUser){
    closeCartDrawer();
    openAuth('login');
    showToast('Login required', 'Please login to checkout', 'info', '🔒');
    return;
  }
  const total = document.getElementById('cartTotal').textContent;
  showToast('Order Placed! 🎉', `Your order of ${total} is confirmed`, 'success', '📦');
  cart = {};
  document.querySelectorAll('.add-btn').forEach(b=>{b.classList.remove('added'); b.querySelector('span').textContent='ADD';});
  updateCartUI();
  closeCartDrawer();
  startLiveTracking();
});

/* ============ LIVE MAP TRACKING ============ */
const trackingBanner = document.getElementById('trackingBanner');
const mapOverlay = document.getElementById('mapOverlay');
const mapRider = document.getElementById('mapRider');
const progressFill = document.getElementById('progressFill');
const etaText = document.getElementById('etaText');
const distText = document.getElementById('distText');
const statusSteps = document.querySelectorAll('#statusSteps .step-pt');
const trackingSummary = document.getElementById('trackingSummary');
const trackingStatusBadge = document.getElementById('trackingStatusBadge');

const STAGES = [
  {label:'Order Placed', toast:['Order Placed! 🎉','Your order has been confirmed','success','📦'], progress:5},
  {label:'Packed', toast:['Order Packed','Your order is being packed at the dark store','info','📦'], progress:25},
  {label:'Out for Delivery', toast:['Out for Delivery 🛵','Your delivery partner is on the way!','success','🛵'], progress:55},
  {label:'Delivered', toast:['Delivered! ✅','Your order has been delivered. Enjoy!','success','🎉'], progress:100}
];

function startLiveTracking(){
  clearInterval(trackingTimer);
  trackingProgress = 0;
  trackingBanner.classList.add('show');
  updateTrackingDisplay();

  let stageIdx = 0;
  showToast(...STAGES[0].toast);
  setStage(0);

  trackingTimer = setInterval(()=>{
    trackingProgress += 5;
    if(trackingProgress >= STAGES[stageIdx+1]?.progress || stageIdx === STAGES.length-1){
      if(stageIdx < STAGES.length-1){
        stageIdx++;
        setStage(stageIdx);
        showToast(...STAGES[stageIdx].toast);
      }
    }
    updateTrackingDisplay();
    if(trackingProgress >= 100){
      clearInterval(trackingTimer);
      setTimeout(()=>{
        trackingBanner.classList.remove('show');
        mapOverlay.classList.remove('show');
      }, 4000);
    }
  }, 1000);
}

function setStage(idx){
  statusSteps.forEach((s,i)=> s.classList.toggle('active', i<=idx));
}

function updateTrackingDisplay(){
  const pct = Math.min(trackingProgress,100);
  progressFill.style.width = pct + '%';
  mapRider.style.left = (8 + (pct/100)*84) + '%';

  const totalKm = 2.0;
  const remainingKm = (totalKm * (1 - pct/100)).toFixed(1);
  const remainingMin = Math.max(1, Math.ceil((100-pct)/100*8));

  distText.textContent = remainingKm + ' km';
  etaText.textContent = remainingMin + ' min';
  trackingSummary.textContent = `Rider is ${remainingKm} km away`;
  trackingStatusBadge.textContent = pct>=100 ? 'Delivered ✅' : `Arriving in ${remainingMin} min`;

  if(pct>=100){
    distText.textContent = '0.0 km';
    etaText.textContent = '0 min';
  }
}

trackingBanner.addEventListener('click', ()=>{
  mapOverlay.classList.add('show');
});
document.getElementById('closeMap').addEventListener('click', ()=>mapOverlay.classList.remove('show'));
mapOverlay.addEventListener('click', (e)=>{ if(e.target===mapOverlay) mapOverlay.classList.remove('show'); });
document.getElementById('trackOrderItem').addEventListener('click', ()=>{
  if(trackingBanner.classList.contains('show')){
    document.getElementById('profileOverlay').classList.remove('show');
    mapOverlay.classList.add('show');
  } else {
    showToast('No active orders', 'Place an order to see live tracking', 'info', '📦');
  }
});

/* ============ AUTH MODAL LOGIC ============ */
const authOverlay = document.getElementById('authOverlay');
function openAuth(step='login'){
  authOverlay.classList.add('show');
  showStep(step);
}
function closeAuth(){
  authOverlay.classList.remove('show');
  clearInterval(resendInterval);
}
document.getElementById('loginOpenBtn').addEventListener('click', ()=>openAuth('login'));
document.getElementById('heroSignup').addEventListener('click', ()=>openAuth('signup'));
document.getElementById('closeAuth').addEventListener('click', closeAuth);
authOverlay.addEventListener('click', (e)=>{ if(e.target===authOverlay) closeAuth(); });

document.getElementById('goSignup').addEventListener('click', ()=>showStep('signup'));
document.getElementById('goLogin').addEventListener('click', ()=>showStep('login'));

function showStep(id){
  document.querySelectorAll('.step').forEach(s=>s.classList.remove('active'));
  document.getElementById(`step-${id}`).classList.add('active');
}

function validatePhone(input, group){
  const val = input.value.trim();
  const valid = /^[6-9]\d{9}$/.test(val);
  group.classList.toggle('invalid', !valid);
  return valid;
}

document.getElementById('loginSendOtp').addEventListener('click', ()=>{
  const input = document.getElementById('loginPhone');
  const group = document.getElementById('loginPhoneGroup');
  if(!validatePhone(input, group)) return;
  pendingPhone = input.value.trim();
  pendingName = "";
  signupMode = false;
  sendOtp();
});

document.getElementById('signupSendOtp').addEventListener('click', ()=>{
  const nameInput = document.getElementById('signupName');
  const nameGroup = document.getElementById('signupNameGroup');
  const phoneInput = document.getElementById('signupPhone');
  const phoneGroup = document.getElementById('signupPhoneGroup');
  const emailInput = document.getElementById('signupEmail');
  const emailGroup = document.getElementById('signupEmailGroup');

  let valid = true;
  if(nameInput.value.trim().length < 2){ nameGroup.classList.add('invalid'); valid=false; } else nameGroup.classList.remove('invalid');
  if(!validatePhone(phoneInput, phoneGroup)) valid=false;
  if(emailInput.value.trim() && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value.trim())){ emailGroup.classList.add('invalid'); valid=false; } else emailGroup.classList.remove('invalid');

  if(!valid) return;
  pendingPhone = phoneInput.value.trim();
  pendingName = nameInput.value.trim();
  signupMode = true;
  sendOtp();
});

function sendOtp(){
  generatedOtp = String(Math.floor(1000 + Math.random()*9000));
  document.getElementById('otpPhoneDisplay').textContent = `+91 ${pendingPhone}`;
  showStep('otp');
  const otpInputs = document.querySelectorAll('.otp-inputs input');
  otpInputs.forEach(i=>{ i.value=''; i.classList.remove('filled'); });
  otpInputs[0].focus();
  startResendTimer();
  showToast('OTP Sent 📩', `Verification code sent to +91 ${pendingPhone}`, 'info', '📲');
  setTimeout(()=>showToast('Demo OTP', `Your code is ${generatedOtp}`, 'info', '🔑'), 900);
}

const otpInputs = document.querySelectorAll('.otp-inputs input');
otpInputs.forEach((input, idx)=>{
  input.addEventListener('input', ()=>{
    input.value = input.value.replace(/[^0-9]/g,'');
    if(input.value){
      input.classList.add('filled');
      if(idx < otpInputs.length-1) otpInputs[idx+1].focus();
    } else {
      input.classList.remove('filled');
    }
  });
  input.addEventListener('keydown', (e)=>{
    if(e.key === 'Backspace' && !input.value && idx>0) otpInputs[idx-1].focus();
  });
});

function startResendTimer(){
  let time = 30;
  const timerEl = document.getElementById('resendTimer');
  timerEl.textContent = `${time}s`;
  timerEl.classList.add('disabled');
  clearInterval(resendInterval);
  resendInterval = setInterval(()=>{
    time--;
    if(time<=0){
      clearInterval(resendInterval);
      timerEl.textContent = 'Resend';
      timerEl.classList.remove('disabled');
      timerEl.onclick = ()=>sendOtp();
    } else {
      timerEl.textContent = `${time}s`;
    }
  },1000);
}

document.getElementById('verifyOtpBtn').addEventListener('click', ()=>{
  const entered = Array.from(otpInputs).map(i=>i.value).join('');
  if(entered.length < 4){
    showToast('Incomplete OTP', 'Please enter all 4 digits', 'error', '⚠️');
    return;
  }
  if(entered !== generatedOtp){
    showToast('Invalid OTP', 'The code entered is incorrect', 'error', '❌');
    otpInputs.forEach(i=>i.style.borderColor = '#e74c3c');
    setTimeout(()=>otpInputs.forEach(i=>i.style.borderColor=''), 700);
    return;
  }
  currentUser = {
    name: signupMode ? pendingName : (loadUser(pendingPhone)?.name || 'User'),
    phone: pendingPhone,
    verified: true
  };
  saveUser(currentUser);
  showStep('success');
});

document.getElementById('doneBtn').addEventListener('click', ()=>{
  closeAuth();
  renderAuthArea();
  showToast(signupMode ? 'Account Created! 🎉' : 'Welcome back! 👋', `Logged in as +91 ${currentUser.phone}`, 'success', '✅');
  setTimeout(()=>showToast('Account Verified', 'Your account is now safe & verified', 'success', '🛡️'), 1200);
});

const userDB = {};
function saveUser(user){ userDB[user.phone] = user; }
function loadUser(phone){ return userDB[phone]; }

/* ============ AUTH AREA / PROFILE ============ */
function renderAuthArea(){
  const area = document.getElementById('authArea');
  if(currentUser){
    const initial = currentUser.name ? currentUser.name.charAt(0).toUpperCase() : 'U';
    area.innerHTML = `<div class="avatar-circle" id="avatarBtn">${initial}</div>`;
    document.getElementById('avatarBtn').addEventListener('click', openProfile);
  } else {
    area.innerHTML = `<button class="login-btn" id="loginOpenBtn">Login</button>`;
    document.getElementById('loginOpenBtn').addEventListener('click', ()=>openAuth('login'));
  }
}

const profileOverlay = document.getElementById('profileOverlay');
function openProfile(){
  document.getElementById('profileAvatarInitial').textContent = currentUser.name.charAt(0).toUpperCase();
  document.getElementById('profileName').textContent = currentUser.name || 'User';
  document.getElementById('profilePhone').textContent = `+91 ${currentUser.phone}`;
  profileOverlay.classList.add('show');
}
document.getElementById('closeProfile').addEventListener('click', ()=>profileOverlay.classList.remove('show'));
profileOverlay.addEventListener('click', (e)=>{ if(e.target===profileOverlay) profileOverlay.classList.remove('show'); });

document.getElementById('logoutBtn').addEventListener('click', ()=>{
  currentUser = null;
  profileOverlay.classList.remove('show');
  renderAuthArea();
  showToast('Logged out', 'You have been logged out successfully', 'info', '👋');
});

/* ============ SCROLL REVEAL ============ */
const revealEls = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries)=>{
  entries.forEach(entry=>{
    if(entry.isIntersecting) entry.target.classList.add('visible');
  });
},{threshold:0.15});
revealEls.forEach(el=>observer.observe(el));

/* ============ MOBILE BOTTOM NAV ============ */
const bnItems = document.querySelectorAll('.bn-item');
bnItems.forEach(item=>{
  item.addEventListener('click', ()=>{
    bnItems.forEach(i=>i.classList.remove('active'));
    item.classList.add('active');
    const action = item.dataset.action;
    if(action === 'home') window.scrollTo({top:0,behavior:'smooth'});
    else if(action === 'categories') document.getElementById('categories').scrollIntoView({behavior:'smooth'});
    else if(action === 'cart') document.getElementById('cartBtn').click();
    else if(action === 'track'){
      if(trackingBanner.classList.contains('show')) mapOverlay.classList.add('show');
      else showToast('No active orders', 'Place an order to see live tracking', 'info', '📦');
    }
    else if(action === 'profile'){
      if(currentUser) openProfile();
      else openAuth('login');
    }
  });
});
// keep bottom-nav cart badge in sync
const _origUpdateCartUI = updateCartUI;
updateCartUI = function(){
  _origUpdateCartUI();
  const count = Object.values(cart).reduce((a,b)=>a+b,0);
  const badge = document.getElementById('bnCartBadge');
  if(count>0){ badge.style.display='flex'; badge.textContent=count; }
  else badge.style.display='none';
