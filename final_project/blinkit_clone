      <div class="item"><div class="left">📍 Saved Addresses</div><span>›</span></div>
      <div class="item"><div class="left">💳 Payment Methods</div><span>›</span></div>
      <div class="item"><div class="left">🔔 Notifications</div><span>›</span></div>
      <div class="item"><div class="left">⚙️ Settings</div><span>›</span></div>
      <div class="item logout" id="logoutBtn"><div class="left">🚪 Logout</div><span>›</span></div>
    </div>
  </div>
</div>

<!-- ===== LIVE MAP TRACKING MODAL ===== -->
<div class="overlay" id="mapOverlay">
  <div class="map-modal">
    <div class="map-header">
      <h3>🛵 Live Order Tracking</h3>
      <button class="modal-close" id="closeMap">×</button>
    </div>
    <div class="map-canvas-wrap">
      <div class="route-line"></div>
      <div class="map-point store">🏬</div>
      <div class="map-rider" id="mapRider">🛵</div>
      <div class="map-point home">🏠</div>
    </div>
    <div class="map-info">
      <div class="map-eta">
        <div>
          <div class="label">Estimated arrival</div>
          <div class="big" id="etaText">8 min</div>
        </div>
        <div style="text-align:right;">
          <div class="label">Distance left</div>
          <div class="big" id="distText">1.8 km</div>
        </div>
      </div>
