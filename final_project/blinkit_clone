      <a href="#">Careers</a>
      <a href="#">Blog</a>
    </div>
    <div>
      <h4>Customer Service</h4>
      <a href="#">Help Center</a>
      <a href="#">Track Order</a>
      <a href="#">Returns</a>
    </div>
    <div>
      <h4>Legal</h4>
      <a href="#">Terms</a>
      <a href="#">Privacy Policy</a>
      <a href="#">Refund Policy</a>
    </div>
    <div>
      <h4>Connect</h4>
