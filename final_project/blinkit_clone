<section class="section reveal" id="products">
  <div class="section-title">Best Sellers <span class="tag">View all ›</span></div>
  <div class="product-grid" id="productGrid"></div>
</section>

<!-- ===== TRUST STRIP ===== -->
<section class="trust-strip reveal">
  <div class="trust-item">
    <div class="icon">🛡️</div>
    <div><h4>100% Verified Sellers <span class="verified-tick">✔</span></h4><p>Every product sourced from trusted, quality-checked partners.</p></div>
  </div>
  <div class="trust-item">
    <div class="icon">🔔</div>
    <div><h4>Instant Order Alerts</h4><p>Real-time notifications for order placed, packed & delivered.</p></div>
  </div>
  <div class="trust-item">
    <div class="icon">🔒</div>
    <div><h4>Secure OTP Login</h4><p>Your account is protected with one-time password verification.</p></div>
  </div>
  <div class="trust-item">
    <div class="icon">🗺️</div>
    <div><h4>Live Order Tracking</h4><p>Watch your delivery partner move toward you in real-time.</p></div>
  </div>
</section>

<!-- ===== FOOTER ===== -->
<footer>
