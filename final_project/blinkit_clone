        <input type="email" id="signupEmail" placeholder="you@example.com">
        <div class="error-msg">Please enter a valid email</div>
      </div>
      <button class="modal-btn" id="signupSendOtp">Send OTP</button>
      <div class="switch-link">Already have an account? <b id="goLogin">Login</b></div>
    </div>

    <div class="step" id="step-otp">
      <h2>🔐 Verify OTP</h2>
      <p class="subtitle">Enter the 4-digit code sent to <b id="otpPhoneDisplay"></b></p>
      <div class="otp-inputs">
        <input type="text" maxlength="1" inputmode="numeric">
        <input type="text" maxlength="1" inputmode="numeric">
        <input type="text" maxlength="1" inputmode="numeric">
        <input type="text" maxlength="1" inputmode="numeric">
      </div>
      <button class="modal-btn" id="verifyOtpBtn">Verify & Continue</button>
      <div class="resend-row">Resend OTP in <b id="resendTimer">30s</b></div>
