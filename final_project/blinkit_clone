</footer>

<!-- ===== AUTH MODAL ===== -->
<div class="overlay" id="authOverlay">
  <div class="modal">
    <button class="modal-close" id="closeAuth">×</button>

    <div class="step active" id="step-login">
      <h2>👋 Welcome back</h2>
      <p class="subtitle">Login to continue to QuickKart</p>
      <div class="form-group" id="loginPhoneGroup">
        <label>Mobile Number</label>
        <input type="tel" id="loginPhone" maxlength="10" placeholder="Enter 10-digit number">
        <div class="error-msg">Please enter a valid 10-digit mobile number</div>
      </div>
      <button class="modal-btn" id="loginSendOtp">Send OTP</button>
      <div class="switch-link">New here? <b id="goSignup">Create an account</b></div>
    </div>

    <div class="step" id="step-signup">
      <h2>🎉 Create account</h2>
      <p class="subtitle">Sign up for fast grocery delivery</p>
      <div class="form-group" id="signupNameGroup">
        <label>Full Name</label>
        <input type="text" id="signupName" placeholder="Enter your name">
        <div class="error-msg">Please enter your name</div>
      </div>
      <div class="form-group" id="signupPhoneGroup">
        <label>Mobile Number</label>
        <input type="tel" id="signupPhone" maxlength="10" placeholder="Enter 10-digit number">
        <div class="error-msg">Please enter a valid 10-digit mobile number</div>
      </div>
      <div class="form-group" id="signupEmailGroup">
